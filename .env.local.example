# Melhor Envio — Token de Acesso Pessoal
# Gerado em: Melhor Envio > Integrações > Tokens > Criar token
MELHOR_ENVIO_TOKEN=seu_token_aqui

# Ambiente: sandbox (testes) ou production
MELHOR_ENVIO_ENV=sandbox

# CEP de origem da loja (endereço de onde sai o pacote)
LOJA_CEP_ORIGEM=00000000

# Identificação do app na API (User-Agent obrigatório pelo Melhor Envio)
APP_EMAIL=email_da_loja@exemplo.com
